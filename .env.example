# Your Azure subscription ID (required)
AZURE_SUBSCRIPTION_ID=

# Optional: restrict to a single resource group
AZURE_RESOURCE_GROUP=

# Optional: paste a bearer token to override az CLI auth.
# Warning: static bearer tokens usually expire in ~1 hour and must be rotated manually.
# If unset, the server runs:
#   az account get-access-token --resource https://management.azure.com
# and refreshes the token automatically. You only need to be logged in with `az login`.
AZURE_TOKEN=

# Optional: how often the browser polls (ms). Default 5000.
NEXT_PUBLIC_REFRESH_MS=5000
